# pfl-forge.yaml — リポジトリルートに配置して pfl-forge を実行
base_branch: main
parallel_workers: 4
models:
  analyze: opus
  implement: sonnet
  implement_complex: opus
  review: sonnet
  reflect: sonnet
  skill: sonnet
  audit: opus
implement_tools:
  - Bash
  - Read
  - Write
  - Edit
  - Glob
  - Grep
analyze_tools:
  - Read
  - Glob
  - Grep
  - Bash
  - WebSearch
  - WebFetch
poll_interval_secs: 300
worktree_dir: .pfl-worktrees
worker_timeout_secs: 1200
analyze_timeout_secs: 600
max_review_retries: 2
# worktree_setup:
#   - npm install
mcp_config: .claude/mcp.json
memory_server: memory-pfl
